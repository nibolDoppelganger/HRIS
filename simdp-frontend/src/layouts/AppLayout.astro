---
import '../styles/global.css';
import { Sidebar } from '../components/shared/Sidebar';
import { Header } from '../components/shared/Header';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | SIMDP LAZWaf Al Azhar</title>
    <!-- Google Fonts: Plus Jakarta Sans & JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block" rel="stylesheet" />
    <!-- Client-side session protection with dev auto-login -->
    <script is:inline>
      (function() {
        var sessionRaw = localStorage.getItem('simdp_session');
        var valid = false;
        if (sessionRaw) {
          try {
            var session = JSON.parse(sessionRaw);
            if (session.expires_at && session.expires_at > Date.now()) {
              valid = true;
            } else {
              localStorage.removeItem('simdp_session');
            }
          } catch(e) {
            localStorage.removeItem('simdp_session');
          }
        }
        if (!valid) {
          // Auto-create demo Super Admin session for development
          var demoSession = {
            session_token: 'demo_' + Math.random().toString(36).substring(2, 11),
            expires_at: Date.now() + (24 * 60 * 60 * 1000),
            user: {
              email: 'admin@alazhar.or.id',
              nama: 'Roni Hermawan (Super Admin)',
              role_id: 'super_admin',
              role_name: 'Super Admin',
              departement: 'Direksi',
              permissions: {
                landing_page: { view:true, create:true, edit:true, delete:true, export:true },
                rekrutmen: { view:true, create:true, edit:true, delete:true, export:true },
                dashboard: { view:true, create:true, edit:true, delete:true, export:true },
                pegawai: { view:true, create:true, edit:true, delete:true, export:true },
                karir: { view:true, create:true, edit:true, delete:true, export:true },
                master: { view:true, create:true, edit:true, delete:true, export:true },
                laporan: { view:true, create:true, edit:true, delete:true, export:true },
                hak_akses: { view:true, create:true, edit:true, delete:true, export:true },
                audit_log: { view:true, create:true, edit:true, delete:true, export:true },
                settings: { view:true, create:true, edit:true, delete:true, export:true }
              }
            }
          };
          localStorage.setItem('simdp_session', JSON.stringify(demoSession));
        }
      })();
    </script>

    <style>
      /* Font styling handled by global.css */
    </style>
  </head>
  <body class="min-h-screen bg-[#f8f9ff] text-[#0b1c30] relative lg:pl-[260px] pt-[80px]">
    <!-- Sidebar Island -->
    <Sidebar currentPath={Astro.url.pathname} client:load />

    <!-- Header Island -->
    <Header title={title} client:load />

    <!-- Page Content Slot -->
    <main class="p-4 sm:p-6 lg:p-8">
      <slot />
    </main>
  </body>
</html>
