---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | LAZWaf Al Azhar</title>
    <meta name="description" content="Sistem Informasi Manajemen Data Pegawai - Lembaga Amil Zakat Wakaf Al Azhar" />
    <!-- Google Fonts: Inter (Body) & Plus Jakarta Sans (Headings) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Plus Jakarta Sans', sans-serif;
      }
    </style>
  </head>
  <body class="bg-[#f8f9ff] text-[#0b1c30] min-h-screen flex flex-col">
    <!-- Navbar -->
    <header class="bg-white/80 backdrop-blur-md border-b border-blue-50/50 sticky top-0 z-50 animate-fade-in-down">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 bg-[#0053d0] rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-md shadow-blue-500/20 transition-all duration-300">
            LA
          </div>
          <div>
            <span class="font-extrabold text-lg text-[#0b1c30] tracking-tight block">LAZWaf Al Azhar</span>
            <span class="text-xs text-[#0053d0] font-semibold block -mt-1">SIM Data Pegawai</span>
          </div>
        </a>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="sm:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors" aria-label="Toggle menu">
          <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>

        <!-- Desktop nav -->
        <nav class="hidden sm:flex items-center gap-6">
          <a href="/" class="text-sm font-bold text-[#434654] hover:text-[#0053d0] transition-colors duration-200">Beranda</a>
          <a href="/rekrutmen" class="text-sm font-bold text-[#434654] hover:text-[#0053d0] transition-colors duration-200">Gabung Amil Zakat LAZ Al Azhar</a>
        </nav>
      </div>

      <!-- Mobile nav dropdown -->
      <nav id="mobile-menu" class="hidden sm:hidden flex-col bg-white border-t border-blue-50/50 px-4 pb-4 space-y-2 animate-fade-in-down">
        <a href="/" class="block py-2.5 px-3 text-sm font-bold text-[#434654] hover:text-[#0053d0] hover:bg-blue-50/50 rounded-lg transition-colors">Beranda</a>
        <a href="/rekrutmen" class="block py-2.5 px-3 text-sm font-bold text-[#434654] hover:text-[#0053d0] hover:bg-blue-50/50 rounded-lg transition-colors">Gabung Amil Zakat LAZ Al Azhar</a>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white text-[#737686] py-8 border-t border-blue-50/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-[#0053d0] rounded-lg flex items-center justify-center text-white font-bold text-sm">
            LA
          </div>
          <span class="font-bold text-[#0b1c30] text-sm">LAZWaf Al Azhar</span>
        </div>
        <p class="text-xs text-[#737686] font-medium">
          © {new Date().getFullYear()} Lembaga Amil Zakat Wakaf Al Azhar. All Rights Reserved.
        </p>
      </div>
    </footer>

    <!-- Mobile menu toggle script -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        if (btn && menu) {
          btn.addEventListener('click', function() {
            menu.classList.toggle('hidden');
            menu.classList.toggle('mobile-nav-open');
          });
        }
      });
    </script>
  </body>
</html>
